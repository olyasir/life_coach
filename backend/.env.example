ANTHROPIC_API_KEY=sk-ant-...
PORT=3001

# Google OAuth — get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Dev flags (set to "1" to enable)
# DEV_DISABLE_TIME_FLOOR=1   # allow coach to close sessions before 45 min
# DEV_DISABLE_COOLDOWN=1     # skip the 7-day weekly gate between sessions
# DEBUG_ROUTES=1             # enable /api/debug/goto and /api/debug/reset
